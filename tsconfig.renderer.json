{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "types": ["vite/client"],
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@renderer/*": ["apps/desktop/renderer/src/*"],
      "@setsuna-desktop/contracts": ["packages/contracts/src/index.ts"]
    }
  },
  "include": [
    "apps/desktop/renderer/src/**/*.ts",
    "apps/desktop/renderer/src/**/*.tsx",
    "apps/desktop/renderer/test/**/*.ts",
    "apps/desktop/renderer/test/**/*.tsx"
  ],
  "references": [
    { "path": "./packages/contracts/tsconfig.build.json" }
  ]
}
