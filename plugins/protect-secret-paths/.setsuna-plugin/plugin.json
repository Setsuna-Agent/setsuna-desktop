{
  "schemaVersion": 1,
  "id": "protect-secret-paths",
  "name": "保护密钥文件路径",
  "icon": "protect-secret-paths",
  "version": "1.0.0",
  "description": "读取、写入或修改参数中出现密钥与凭证文件路径时直接拦截。",
  "publisher": "Setsuna",
  "tags": ["安全", "密钥", "文件"],
  "featured": false,
  "hooks": [
    {
      "id": "protect-secret-paths",
      "name": "保护密钥文件路径",
      "description": "保护 .env、SSH 私钥、npm/pypi 凭证和服务账号文件。",
      "eventName": "PreToolUse",
      "matcher": "workspace_read_file|workspace_write_file|read_file|write_file|edit|edit_file|append_file|delete_file|apply_patch",
      "command": "node {{pluginRoot}}/hooks/protect-secret-paths.mjs",
      "commandWindows": "node {{pluginRoot}}/hooks/protect-secret-paths.mjs",
      "timeoutSec": 10,
      "statusMessage": "检查敏感文件"
    }
  ]
}
