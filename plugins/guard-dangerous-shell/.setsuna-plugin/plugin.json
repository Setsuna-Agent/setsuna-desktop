{
  "schemaVersion": 1,
  "id": "guard-dangerous-shell",
  "name": "阻止危险 Shell 命令",
  "icon": "guard-dangerous-shell",
  "version": "1.0.1",
  "description": "拦截删除根目录、格式化磁盘、强制清理 Git 工作区等高危命令。",
  "publisher": "Setsuna",
  "tags": ["安全", "Shell", "防护"],
  "featured": false,
  "hooks": [
    {
      "id": "guard-dangerous-shell",
      "name": "阻止危险 Shell 命令",
      "description": "在 Shell 工具执行前识别破坏性命令，命中后阻止本次调用。",
      "eventName": "PreToolUse",
      "matcher": "run_shell_command|exec_command",
      "command": "node {{pluginRoot}}/hooks/guard-dangerous-shell.mjs",
      "commandWindows": "node {{pluginRoot}}/hooks/guard-dangerous-shell.mjs",
      "timeoutSec": 10,
      "statusMessage": "检查危险命令"
    }
  ]
}
