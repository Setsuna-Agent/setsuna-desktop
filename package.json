{
  "name": "setsuna-desktop",
  "version": "0.1.7",
  "packageManager": "pnpm@7.33.7",
  "description": "Local-first desktop runtime and workbench for Setsuna Agent workflows.",
  "author": {
    "name": "Setsuna Agent",
    "email": "1182900548@qq.com"
  },
  "license": "MIT",
  "type": "module",
  "main": "dist/electron/main/index.js",
  "private": false,
  "scripts": {
    "dev": "concurrently -k -n renderer,electron \"pnpm dev:renderer\" \"wait-on tcp:5174 && pnpm dev:electron\"",
    "dev:renderer": "vite --host 127.0.0.1 --port 5174",
    "dev:electron": "tsx scripts/start-electron-dev.ts",
    "build": "pnpm clean && pnpm build:contracts && pnpm build:runtime && pnpm build:electron && pnpm build:renderer",
    "build:contracts": "tsc -b packages/contracts",
    "build:runtime": "tsc -b packages/desktop-runtime",
    "build:electron": "tsx scripts/build-electron.ts",
    "build:renderer": "vite build",
    "clean": "node scripts/clean.mjs",
    "lint": "eslint . --max-warnings=0",
    "package": "node scripts/validate-release-version.mjs && pnpm build && electron-builder --dir",
    "package:linux:x64": "node scripts/validate-release-version.mjs && pnpm build && electron-builder --linux --x64 --publish never",
    "package:mac:arm64": "node scripts/validate-release-version.mjs && pnpm build && electron-builder --mac --arm64 --publish never",
    "package:mac:x64": "node scripts/validate-release-version.mjs && pnpm build && electron-builder --mac --x64 --publish never",
    "package:win:x64": "node scripts/validate-release-version.mjs && pnpm build && electron-builder --win --x64 --publish never --config.npmRebuild=false",
    "postinstall": "node scripts/prepare-node-pty.mjs",
    "release:dry-run": "node scripts/validate-release-version.mjs && pnpm build && node scripts/release-dry-run.mjs",
    "start": "electron .",
    "test": "pnpm test:unit && pnpm test:integration",
    "test:all": "vitest run --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:release": "vitest run --config vitest.release.config.ts",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "typecheck": "tsc -b --pretty false",
    "validate:release-version": "node scripts/validate-release-version.mjs"
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.5",
    "@ant-design/x": "^2.5.0",
    "@fontsource/geist-mono": "^5.2.8",
    "@fontsource/geist-sans": "^5.2.5",
    "@setsuna-desktop/contracts": "workspace:*",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "antd": "^6.3.6",
    "katex": "^0.16.22",
    "lucide-react": "^0.468.0",
    "marked": "^17.0.1",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "refractor": "5.0.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remend": "^1.3.0",
    "seti-file-icons": "^0.0.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^43.1.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.2",
    "eslint": "^9.17.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8",
    "wait-on": "^8.0.1"
  },
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=7"
  },
  "build": {
    "appId": "dev.setsuna.desktop",
    "productName": "Setsuna Desktop",
    "afterPack": "scripts/after-pack-mac.cjs",
    "directories": {
      "output": "release-artifacts",
      "buildResources": "assets/build"
    },
    "files": [
      "dist/**/*",
      "package.json",
      "packages/contracts/package.json",
      "packages/desktop-runtime/package.json",
      "skills/**/*",
      "plugins/**/*"
    ],
    "asarUnpack": [
      "**/node_modules/node-pty/prebuilds/**/*"
    ],
    "mac": {
      "icon": "assets/build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "Setsuna-Desktop-${version}-mac-${arch}.${ext}",
      "identity": null
    },
    "win": {
      "icon": "assets/build/icon.ico",
      "target": [
        "nsis",
        "zip"
      ],
      "artifactName": "Setsuna-Desktop-${version}-windows-${arch}.${ext}"
    },
    "linux": {
      "icon": "assets/build/icon.png",
      "target": [
        "AppImage",
        "deb",
        "tar.gz"
      ],
      "category": "Development",
      "artifactName": "Setsuna-Desktop-${version}-ubuntu-${arch}.${ext}"
    }
  }
}